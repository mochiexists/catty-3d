    },
    "Layout %@ not yet implemented — showing active session only" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Layout %@ noch nicht implementiert — nur aktive Sitzung wird angezeigt" } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "El diseño %@ aún no está implementado — mostrando solo la sesión activa" } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "El diseño %@ aún no está implementado — mostrando solo la sesión activa" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Disposition %@ pas encore implémentée — affichage de la session active uniquement" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Layout %@ non ancora implementato — visualizzo solo la sessione attiva" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "レイアウト %@ は未実装です — アクティブなセッションのみ表示します" } },

    "Open a local terminal or connect via SSH to get started." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Öffne ein lokales Terminal oder verbinde dich per SSH, um loszulegen." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Abre una terminal local o conéctate por SSH para empezar." } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "Abre un terminal local o conéctate por SSH para empezar." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ouvrez un terminal local ou connectez-vous en SSH pour commencer." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Apri un terminale locale o connettiti via SSH per iniziare." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ローカルターミナルを開くか、SSH で接続して始めましょう。" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Open een lokale terminal of maak verbinding via SSH om te beginnen." } },

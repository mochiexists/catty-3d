    },
    "Inspired by Ratty" : {
      "comment" : "Attribution preamble. \"Ratty\" stays English (DNT).",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Inspiriert von Ratty" } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Inspirado en Ratty" } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "Inspirado en Ratty" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Inspiré par Ratty" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ispirato a Ratty" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Ratty にインスパイア" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Geïnspireerd door Ratty" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Inspirado em Ratty" } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Inspirado em Ratty" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "灵感来自 Ratty" } }
      }
    },
    "The terminal-in-a-3D-scene idea behind Catty 3D comes from Ratty by Orhun Parmaksız — a GPU-rendered terminal with inline 3D graphics. Their rat chases pixels in a terminal; our cat watches it happen from RealityKit." : {
      "comment" : "Long marketing/attribution copy. \"Catty 3D\", \"Ratty\", \"Orhun Parmaksız\", and \"RealityKit\" are DNT.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Idee, ein Terminal in eine 3D-Szene zu setzen, hinter Catty 3D stammt von Ratty von Orhun Parmaksız — ein GPU-gerendertes Terminal mit eingebetteten 3D-Grafiken. Ihre Ratte jagt Pixel in einem Terminal; unsere Katze schaut von RealityKit aus zu." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "La idea de la terminal dentro de una escena 3D que hay detrás de Catty 3D viene de Ratty, de Orhun Parmaksız: una terminal renderizada por GPU con gráficos 3D integrados. Su rata persigue píxeles en una terminal; nuestro gato lo contempla desde RealityKit." } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "La idea del terminal dentro de una escena 3D que hay detrás de Catty 3D viene de Ratty, de Orhun Parmaksız: un terminal renderizado por GPU con gráficos 3D integrados. Su rata persigue píxeles en un terminal; nuestro gato lo contempla desde RealityKit." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'idée d'un terminal dans une scène 3D derrière Catty 3D vient de Ratty d'Orhun Parmaksız — un terminal rendu par GPU avec des graphismes 3D intégrés. Leur rat poursuit des pixels dans un terminal ; notre chat observe la scène depuis RealityKit." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "L'idea di un terminale dentro una scena 3D dietro Catty 3D viene da Ratty di Orhun Parmaksız — un terminale renderizzato dalla GPU con grafica 3D integrata. Il loro topo insegue pixel in un terminale; il nostro gatto guarda la scena da RealityKit." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Catty 3D の「3D シーンの中の端末」というアイデアは、Orhun Parmaksız 氏の Ratty に由来します — GPU レンダリングで 3D グラフィックスをインライン表示する端末です。彼らのネズミが端末内でピクセルを追いかけ、私たちの猫が RealityKit からその様子を眺めています。" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Het idee van een terminal in een 3D-scène achter Catty 3D komt van Ratty van Orhun Parmaksız — een GPU-gerenderde terminal met ingebouwde 3D-graphics. Hun rat jaagt op pixels in een terminal; onze kat kijkt toe vanuit RealityKit." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "A ideia de um terminal dentro de uma cena 3D por trás do Catty 3D vem do Ratty, de Orhun Parmaksız — um terminal renderizado por GPU com gráficos 3D integrados. O rato deles persegue pixels num terminal; nosso gato observa tudo a partir do RealityKit." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "A ideia de um terminal dentro de uma cena 3D por trás de Catty 3D vem de Ratty, de Orhun Parmaksız — um terminal renderizado por GPU com gráficos 3D integrados. O rato deles persegue píxeis num terminal; o nosso gato observa tudo a partir do RealityKit." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Catty 3D 中“将终端置入 3D 场景”的灵感来自 Orhun Parmaksız 的 Ratty——一个用 GPU 渲染、内嵌 3D 图形的终端。他们的老鼠在终端里追逐像素；我们的猫从 RealityKit 中看着这一切发生。" } }
      }
    },
    "The rat 3D model in this scene also ships courtesy of Ratty (MIT). Maxwell the cat comes from bean (alwayshasbean) on Sketchfab under CC-BY 4.0." : {
      "comment" : "Asset attribution. \"Ratty\", \"Maxwell\", \"bean\", \"alwayshasbean\", \"Sketchfab\", \"MIT\", \"CC-BY 4.0\" are DNT.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das 3D-Modell der Ratte in dieser Szene stammt ebenfalls von Ratty (MIT). Maxwell die Katze stammt von bean (alwayshasbean) auf Sketchfab unter CC-BY 4.0." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "El modelo 3D de la rata en esta escena también se incluye gracias a Ratty (MIT). Maxwell, el gato, viene de bean (alwayshasbean) en Sketchfab bajo CC-BY 4.0." } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "El modelo 3D de la rata en esta escena también se incluye gracias a Ratty (MIT). Maxwell, el gato, viene de bean (alwayshasbean) en Sketchfab bajo CC-BY 4.0." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le modèle 3D du rat dans cette scène est également fourni par Ratty (MIT). Maxwell le chat vient de bean (alwayshasbean) sur Sketchfab sous licence CC-BY 4.0." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Anche il modello 3D del topo in questa scena è fornito da Ratty (MIT). Maxwell il gatto viene da bean (alwayshasbean) su Sketchfab con licenza CC-BY 4.0." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "このシーンのネズミの 3D モデルも Ratty (MIT) によるものです。Maxwell（猫）は Sketchfab の bean (alwayshasbean) による作品で、CC-BY 4.0 ライセンスです。" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Het 3D-model van de rat in deze scène komt ook van Ratty (MIT). Maxwell de kat komt van bean (alwayshasbean) op Sketchfab onder CC-BY 4.0." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O modelo 3D do rato nesta cena também é cortesia do Ratty (MIT). Maxwell, o gato, vem do bean (alwayshasbean) no Sketchfab, sob CC-BY 4.0." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "O modelo 3D do rato nesta cena também é cortesia de Ratty (MIT). Maxwell, o gato, vem de bean (alwayshasbean) no Sketchfab, sob CC-BY 4.0." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本场景中的老鼠 3D 模型同样由 Ratty (MIT) 提供。Maxwell 这只猫来自 Sketchfab 上的 bean (alwayshasbean)，依据 CC-BY 4.0 许可。" } }
      }
    },

    "Send Maxwell after the rat — zoom out to watch the chase" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Schick Maxwell hinter der Ratte her — zoom raus, um die Jagd zu sehen" } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Manda a Maxwell tras la rata — aleja la cámara para ver la persecución" } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "Manda a Maxwell tras la rata — aleja la cámara para ver la persecución" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Lance Maxwell à la poursuite du rat — dézoome pour voir la course" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Manda Maxwell all'inseguimento del topo — allontana la camera per vedere la corsa" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Maxwell をネズミに差し向ける — ズームアウトして追いかけっこを見守ろう" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Stuur Maxwell achter de rat aan — zoom uit om de jacht te volgen" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Mande o Maxwell atrás do rato — afaste a câmera para ver a perseguição" } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Manda o Maxwell atrás do rato — afasta a câmara para ver a perseguição" } },

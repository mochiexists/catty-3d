    "Drag to zoom (works even while a terminal is focused)" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zum Zoomen ziehen (funktioniert auch, wenn ein Terminal aktiv ist)" } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Arrastra para hacer zoom (funciona incluso con una terminal en foco)" } },
        "es-ES" : { "stringUnit" : { "state" : "translated", "value" : "Arrastra para hacer zoom (funciona incluso con un terminal en foco)" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Faire glisser pour zoomer (fonctionne même quand un terminal a le focus)" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Trascina per fare zoom (funziona anche con un terminale attivo)" } },

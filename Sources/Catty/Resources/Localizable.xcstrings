        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Abre um terminal local ou liga-te via SSH para começar." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开本地终端或通过 SSH 连接以开始。" } }

.DS_Store
.build/
.swiftpm/
Package.resolved
# XcodeGen output — regenerated from project.yml on demand
*.xcodeproj/
DerivedData/
xcuserdata/
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/
fastlane/.env
fastlane/.env.*
!fastlane/.env.example
fastlane/build/
fastlane/screenshots/macos/*.png
*.profraw

# Local signing + identifier overrides. Each contributor maintains
# their own copy from `Local.example.xcconfig`. NEVER commit.
Local.xcconfig

# App Store Connect API keys (.p8). Local-only, never commit — anyone
# with the file can authenticate to ASC as the issuing account.
fastlane/*.p8
fastlane/AuthKey_*.p8

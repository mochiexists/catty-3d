# fastlane/.env.example
#
# Copy to `fastlane/.env` (gitignored) and fill in for local fastlane runs.
# In CI these come from GitHub Actions secrets exposed as environment
# variables.

# --- App Store Connect API key (preferred over Apple ID + password) ---
ASC_KEY_ID=""
ASC_ISSUER_ID=""
# Either point at a .p8 file on disk OR base64-encode its contents below.
ASC_KEY_PATH=""
# ASC_KEY_CONTENT="<base64 of the .p8 file>"

# --- Notarization (Direct Download path) ---
# Set up the keychain profile once with:
#   xcrun notarytool store-credentials "catty-notary" --apple-id <email> --team-id <team> --password <app-specific>
FASTLANE_NOTARIZATION_PROFILE="catty-notary"

# --- Apple Developer ---
DEVELOPMENT_TEAM=""

# --- Optional: Apple ID fallback (only if not using ASC API key) ---
# FASTLANE_USER=""
# FASTLANE_PASSWORD=""
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=""
